---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import WordPressReview from '~/components/widgets/WordPressReview.astro';

const metadata = {
  title: 'WordPress-Agentur Frankfurt | Websites, Relaunch & Support',
  description:
    'WordPress-Agentur Frankfurt für moderne Websites, Relaunch, Wartung und Support. Klare Beratung, saubere Umsetzung und schnelle Hilfe für Unternehmen in Frankfurt.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->


  <div class="hero-image-wrapper">
    <div class="hero-image">
      <img src="/images/wordpress-webseite-frankfurt.webp" alt="WordPress-Agentur Frankfurt">
    </div>
  </div>

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Kontakt',
        href: '/kontakt',
        target: '',
        icon: 'tabler:mail',
      },
      { text: 'Anrufen',
        href: 'tel:+49-162-7519335',
        icon: 'tabler:phone',
      },
    ]}
  >
    <Fragment slot="title">
      WordPress-Agentur <span class="hidden xl:inline"></span>
      <span class="text-accent dark:text-white highlight"> Frankfurt </span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="block mb-1 sm:hidden font-bold text-blue-600">WordPress, das sauber läuft.</span>
      <span class="colorful">Ihre WordPress-Agentur in Frankfurt am Main.</span>
      Wir erstellen, erneuern und betreuen WordPress-Websites für Unternehmen, die eine verlässliche Website brauchen: klar aufgebaut, schnell, gut pflegbar und bereit für Anfragen.
    </Fragment>
  </Hero>

  <WordPressReview />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="WORDPRESS SERVICES"
    title="Was unsere WordPress-Agentur in Frankfurt macht"
    subtitle="Keine aufgeblähte Agenturleistung, sondern genau das, was eine gute WordPress-Website braucht."
    classes={{
      wrapper: 'bg-slate-100/50 dark:bg-purple-900/20'
    }}
    items={[
      {
        title: 'WordPress-Website erstellen',
        description:
          'Neue Website für Unternehmen, Praxen und Dienstleister: klar strukturiert, mobiloptimiert und einfach zu pflegen.',
        icon: 'tabler:world-www',
      },
      {
        title: 'WordPress-Relaunch',
        description:
          'Wenn die alte Seite langsam, unübersichtlich oder veraltet ist, bringen wir Design, Struktur und Technik auf Stand.',
        icon: 'tabler:refresh',
      },
      {
        title: 'WordPress-SEO',
        description:
          'Wir optimieren Struktur, Ladezeit, Inhalte und lokale Signale, damit Ihre Website in Frankfurt besser gefunden wird.',
        icon: 'tabler:search',
      },
      {
        title: 'Wartung & Sicherheit',
        description:
          'Updates, Backups und Sicherheitschecks sorgen dafür, dass Ihre Website stabil bleibt.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Performance-Optimierung',
        description:
          'Wir prüfen Bilder, Caching, Theme und Plugins, damit WordPress spürbar schneller wird.',
        icon: 'tabler:speedboat',
      },
      {
        title: 'WooCommerce & Erweiterungen',
        description:
          'Formulare, Buchungen, Shops oder Schnittstellen: Wir erweitern WordPress nur dort, wo es sinnvoll ist.',
        icon: 'tabler:shopping-cart',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Warum wir?"
    title="Eine WordPress-Agentur, die praktisch denkt"
    items={[
    {
      title: 'Einfach zu pflegen',
      description:
        'Sie können wichtige Inhalte selbst ändern, ohne für jede Kleinigkeit technische Hilfe zu brauchen.',
    },
    {
      title: 'Technisch sauber umgesetzt',
      description:
        'Wir achten auf Ladezeit, Sicherheit, mobile Darstellung und eine Struktur, die später erweiterbar bleibt.',
    },
    {
      title: 'Mit Blick auf Sichtbarkeit',
      description:
        'SEO ist kein Extra am Ende. Seitenstruktur, Inhalte und Technik werden von Anfang an mitgedacht.',
    },
    ]}
    image={{
      src: '/images/wordpress-webseite-erstellen-frankfurt.webp',
      alt: 'WordPress-Website erstellen Frankfurt',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">WordPress für echte Anfragen, nicht für die Schublade</h3>
      Eine gute Website erklärt Ihr Angebot schnell, wirkt seriös und macht Kontaktaufnahme einfach.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Klarer Prozess',
        description: `Wir starten mit Ziel, Inhalt und Struktur. Danach folgen Design, Umsetzung und ein sauberer Launch.`,
      },
      {
        title: 'Direkter Ansprechpartner',
        description:
          'Sie sprechen direkt mit jemandem, der WordPress, Technik und Website-Strategie versteht.',
      },
      {
        title: 'Betreuung nach dem Launch',
        description:
          "Nach dem Go-live helfen wir mit Wartung, Updates, neuen Seiten und laufenden Verbesserungen.",
      },
    ]}
    image={{
      src: 'images/frankfurt-am-main-commerzbank.webp',
      alt: 'WordPress-Agentur Frankfurt am Main',
    }}
  >
    <Fragment slot="content">Ihre WordPress-Agentur für Frankfurt am Main und das Rhein-Main-Gebiet.</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

   <!-- Features2 Widget ************** -->

   <Features2
   title="Typische Gründe, warum Kunden zu uns kommen"
   subtitle="Viele Projekte starten nicht mit einer perfekten Idee, sondern mit einem konkreten Problem."
   columns={3}
   items={[
     {
       title: 'Neue Website gebraucht',
       description:
         'Sie brauchen eine professionelle WordPress-Website, wissen aber noch nicht genau, wie sie aufgebaut sein soll.',
       icon: 'tabler:sitemap',
     },
     {
       title: 'Alte Seite wirkt nicht mehr',
       description:
         'Design, Inhalte oder Technik passen nicht mehr zum Unternehmen. Wir machen daraus einen klaren Relaunch.',
       icon: 'tabler:device-laptop',
     },
     {
       title: 'WordPress ist zu langsam',
       description: `Lange Ladezeiten, zu viele Plugins oder ein schweres Theme: Wir finden die Ursachen und räumen auf.`,
       icon: 'tabler:settings-search',
     },
     {
       title: 'Inhalte sind unklar',
       description:
         'Wir helfen, Leistungen verständlich zu erklären, ohne die Seite mit Marketingfloskeln zu überladen.',
       icon: 'tabler:writing',
     },
     {
       title: 'Support fehlt',
       description:
         'Updates, kleine Änderungen oder Fehler bleiben liegen. Wir übernehmen die laufende Betreuung.',
       icon: 'tabler:gauge',
     },
     {
       title: 'Mehr Anfragen gewünscht',
       description:
         'Kontaktwege, Seitenstruktur und lokale Sichtbarkeit werden so verbessert, dass Besucher leichter anfragen.',
       icon: 'tabler:shopping-cart',
     },
   ]}
 />

  <FAQs
    title="WordPress-Agentur Frankfurt – häufige Fragen"
    subtitle="Kurz beantwortet, damit Sie schneller einschätzen können, ob WordPress für Ihr Projekt passt."
    columns={1}
    items={[
      {
        title: 'Was macht eine WordPress-Agentur in Frankfurt?',
        description:
          'Wir planen, erstellen und betreuen WordPress-Websites für Unternehmen in Frankfurt. Dazu gehören Webdesign, technische Umsetzung, Wartung, Ladezeit und bei Bedarf SEO.',
      },
      {
        title: 'Ist WordPress für lokale Unternehmen geeignet?',
        description:
          'Ja. WordPress eignet sich gut für Praxen, Kanzleien, Dienstleister und B2B-Unternehmen, weil Inhalte flexibel gepflegt werden können.',
      },
      {
        title: 'Könnt ihr eine bestehende WordPress-Seite überarbeiten?',
        description:
          'Ja. Wir prüfen Technik, Inhalte und Struktur und modernisieren die Seite Schritt für Schritt.',
      },
      {
        title: 'Bietet ihr auch WordPress-Wartung an?',
        description:
          'Ja. Wir übernehmen Updates, Backups, Sicherheitschecks, Fehlerbehebung und kleinere Anpassungen.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Kostenloses Erstgespräch',
        href: '/kontakt',
        target: '',
        icon: 'tabler:message',
      },
    ]}
  >
    <Fragment slot="title">
      Bereit für eine bessere WordPress-Website?<br class="block sm:hidden" /> <span class="sm:whitespace-nowrap">Lassen Sie uns sprechen!</span>
    </Fragment>

    <Fragment slot="subtitle">
      Kurze Nachricht reicht. Wir melden uns zeitnah und sagen ehrlich, was sinnvoll ist.
    </Fragment>
  </CallToAction>
</Layout>


<style>
/* Hero Image Improvements */
.hero-image-wrapper {
  position: relative;
  margin-bottom: 1rem;
}

.hero-image-wrapper::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 450px;
  height: 450px;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(219, 39, 119, 0.1));
  border-radius: 50%;
  filter: blur(80px);
  z-index: -1;
  animation: pulse 4s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.1); }
}

.hero-image {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.hero-image img {
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  border: 4px solid rgba(139, 92, 246, 0.2);
}

.hero-image img:hover {
  transform: scale(1.02);
  box-shadow: 0 20px 60px rgba(139, 92, 246, 0.3);
}

.colorful {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 700;
}

@media (max-width: 768px) {
  .hero-image {
    height: 40vh;
    margin-bottom: 20px;
  }

  .hero-image img {
    max-width: 100%;
    height: auto;
    object-fit: cover;
  }

  .colorful {
    color: #71fffd;
    background: none;
    -webkit-text-fill-color: currentColor;
  }

  .hero-image-wrapper::before {
    width: 300px;
    height: 300px;
  }
}

@media (min-width: 768px) {
  .hero-image img {
    width: 400px;
    height: 400px;
    border-radius: 100%;
    object-fit: cover;
    object-position: top;
  }
}
</style>
