---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import WordPressReview from '~/components/widgets/WordPressReview.astro';

const metadata = {
  title: 'WordPress-Agentur Frankfurt | Websites, Relaunch & Support',
  description:
    'WordPress-Agentur Frankfurt für moderne Websites, Relaunch, Wartung und Support. Klare Beratung, saubere Umsetzung und schnelle Hilfe für Unternehmen in Frankfurt.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->


  <div class="hero-image-wrapper">
    <div class="hero-image">
      <img src="/images/wordpress-webseite-frankfurt.webp" alt="WordPress-Agentur Frankfurt">
    </div>
  </div>

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Kontakt',
        href: '/kontakt',
        target: '',
        icon: 'tabler:mail',
      },
      { text: 'Anrufen',
        href: 'tel:+49-162-7519335',
        icon: 'tabler:phone',
      },
    ]}
  >
    <Fragment slot="title">
      WordPress-Agentur <span class="hidden xl:inline"></span>
      <span class="text-accent dark:text-white highlight"> Frankfurt </span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="block mb-1 sm:hidden font-bold text-blue-600">WordPress, das sauber läuft.</span>
      <span class="colorful">Ihre WordPress-Agentur in Frankfurt am Main.</span>
      Wenn Ihre Website veraltet ist, zu langsam lädt oder zu wenige Anfragen bringt, helfen wir mit einer WordPress-Website, die klar aufgebaut, gut pflegbar und verlässlich ist.
    </Fragment>
  </Hero>

  <WordPressReview />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="WORDPRESS SERVICES"
    title="Wie wir Ihnen mit WordPress helfen"
    subtitle="Für Unternehmen in Frankfurt, die eine bessere Website brauchen, ohne sich selbst um Technik, Plugins und Struktur kümmern zu müssen."
    classes={{
      wrapper: 'bg-slate-100/50 dark:bg-purple-900/20'
    }}
    items={[
      {
        title: 'Sie brauchen eine neue Website',
        description:
          'Wir entwickeln eine WordPress-Website, die Ihr Angebot verständlich zeigt und Besucher schnell zur Anfrage führt.',
        icon: 'tabler:world-www',
      },
      {
        title: 'Ihre alte Seite passt nicht mehr',
        description:
          'Wir erneuern Design, Inhalte und Technik, ohne wichtige Seiten, Weiterleitungen und bestehende Sichtbarkeit zu verlieren.',
        icon: 'tabler:refresh',
      },
      {
        title: 'Sie möchten besser gefunden werden',
        description:
          'Wir verbessern Struktur, Ladezeit, Inhalte und lokale Signale für relevante Suchanfragen in Frankfurt.',
        icon: 'tabler:search',
      },
      {
        title: 'Sie wollen weniger Technikstress',
        description:
          'Updates, Backups und Sicherheitschecks laufen betreut, damit kleine Probleme nicht liegen bleiben.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Ihre Website ist zu langsam',
        description:
          'Wir prüfen Bilder, Caching, Theme und Plugins und machen WordPress spürbar schneller.',
        icon: 'tabler:speedboat',
      },
      {
        title: 'Sie brauchen neue Funktionen',
        description:
          'Formulare, Buchungen, Shops oder Schnittstellen werden so ergänzt, dass die Website nicht unnötig kompliziert wird.',
        icon: 'tabler:shopping-cart',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Was Sie davon haben"
    title="Eine WordPress-Website, die im Alltag hilft"
    items={[
    {
      title: 'Sie bleiben handlungsfähig',
      description:
        'Wichtige Texte, Bilder und Inhalte lassen sich selbst pflegen, ohne jedes Mal Hilfe anzufragen.',
    },
    {
      title: 'Ihre Website bleibt stabil',
      description:
        'Ladezeit, Sicherheit, mobile Darstellung und Erweiterbarkeit werden von Anfang an mitgedacht.',
    },
    {
      title: 'Besucher finden schneller zum Ziel',
      description:
        'Seitenstruktur, Inhalte und Kontaktwege werden so aufgebaut, dass Besucher nicht suchen müssen.',
    },
    ]}
    image={{
      src: '/images/wordpress-webseite-erstellen-frankfurt.webp',
      alt: 'WordPress-Website erstellen Frankfurt',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Ihre Website soll Arbeit abnehmen</h3>
      Eine gute Website beantwortet die wichtigsten Fragen, schafft Vertrauen und macht Kontaktaufnahme einfach.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Sie wissen, was passiert',
        description: `Wir klären Ziel, Inhalt und Struktur, bevor Design und Umsetzung starten.`,
      },
      {
        title: 'Sie sprechen direkt mit uns',
        description:
          'Keine unnötigen Schleifen: Sie sprechen mit jemandem, der WordPress, Technik und Website-Strategie versteht.',
      },
      {
        title: 'Sie stehen nach dem Launch nicht allein da',
        description:
          "Wartung, Updates, neue Seiten und kleinere Verbesserungen bleiben betreut.",
      },
    ]}
    image={{
      src: 'images/frankfurt-am-main-commerzbank.webp',
      alt: 'WordPress-Agentur Frankfurt am Main',
    }}
  >
    <Fragment slot="content">Ihre WordPress-Agentur für Frankfurt am Main und das Rhein-Main-Gebiet.</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

   <!-- Features2 Widget ************** -->

   <Features2
   title="Wobei brauchen Sie Hilfe?"
   subtitle="Viele WordPress-Projekte starten mit einem konkreten Problem. Genau dort setzen wir an."
   columns={3}
   items={[
     {
       title: 'Ich brauche eine neue Website',
       description:
         'Sie haben ein Angebot, aber noch keine Website, die es klar und professionell zeigt.',
       icon: 'tabler:sitemap',
     },
     {
       title: 'Meine alte Seite wirkt nicht mehr',
       description:
         'Design, Inhalte oder Technik passen nicht mehr zu Ihrem Unternehmen und sollen erneuert werden.',
       icon: 'tabler:device-laptop',
     },
     {
       title: 'Meine WordPress-Seite ist zu langsam',
       description: `Lange Ladezeiten, zu viele Plugins oder ein schweres Theme: Wir finden die Ursachen und räumen auf.`,
       icon: 'tabler:settings-search',
     },
     {
       title: 'Meine Inhalte sind unklar',
       description:
         'Ihre Leistungen sollen verständlicher erklärt werden, ohne die Seite mit Marketingfloskeln zu überladen.',
       icon: 'tabler:writing',
     },
     {
       title: 'Mir fehlt WordPress-Support',
       description:
         'Updates, kleine Änderungen oder Fehler bleiben liegen und sollen zuverlässig betreut werden.',
       icon: 'tabler:gauge',
     },
     {
       title: 'Ich möchte mehr Anfragen',
       description:
         'Kontaktwege, Seitenstruktur und lokale Sichtbarkeit sollen Besucher leichter zur Anfrage führen.',
       icon: 'tabler:shopping-cart',
     },
   ]}
 />

  <FAQs
    title="WordPress-Agentur Frankfurt – häufige Fragen"
    subtitle="Kurz beantwortet, damit Sie schneller einschätzen können, ob wir Ihnen helfen können."
    columns={1}
    items={[
      {
        title: 'Was macht eine WordPress-Agentur in Frankfurt?',
        description:
          'Sie bekommen Hilfe bei Planung, Umsetzung und Betreuung Ihrer WordPress-Website: von Struktur und Design bis Wartung, Ladezeit und Sichtbarkeit.',
      },
      {
        title: 'Ist WordPress für lokale Unternehmen geeignet?',
        description:
          'Ja. Besonders Praxen, Kanzleien, Dienstleister und B2B-Unternehmen profitieren davon, dass Inhalte flexibel gepflegt werden können.',
      },
      {
        title: 'Könnt ihr eine bestehende WordPress-Seite überarbeiten?',
        description:
          'Ja. Wenn Ihre Website langsam, unübersichtlich oder veraltet ist, prüfen wir Technik, Inhalte und Struktur und modernisieren Schritt für Schritt.',
      },
      {
        title: 'Bietet ihr auch WordPress-Wartung an?',
        description:
          'Ja. Sie können Updates, Backups, Sicherheitschecks, Fehlerbehebung und kleinere Anpassungen laufend betreuen lassen.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Kostenloses Erstgespräch',
        href: '/kontakt',
        target: '',
        icon: 'tabler:message',
      },
    ]}
  >
    <Fragment slot="title">
      Bereit für eine bessere WordPress-Website?<br class="block sm:hidden" /> <span class="sm:whitespace-nowrap">Lassen Sie uns sprechen!</span>
    </Fragment>

    <Fragment slot="subtitle">
      Kurze Nachricht reicht. Wir melden uns zeitnah und sagen ehrlich, was sinnvoll ist.
    </Fragment>
  </CallToAction>
</Layout>


<style>
/* Hero Image Improvements */
.hero-image-wrapper {
  position: relative;
  margin-bottom: 1rem;
}

.hero-image-wrapper::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 450px;
  height: 450px;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(219, 39, 119, 0.1));
  border-radius: 50%;
  filter: blur(80px);
  z-index: -1;
  animation: pulse 4s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.1); }
}

.hero-image {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.hero-image img {
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  border: 4px solid rgba(139, 92, 246, 0.2);
}

.hero-image img:hover {
  transform: scale(1.02);
  box-shadow: 0 20px 60px rgba(139, 92, 246, 0.3);
}

.colorful {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 700;
}

@media (max-width: 768px) {
  .hero-image {
    height: 40vh;
    margin-bottom: 20px;
  }

  .hero-image img {
    max-width: 100%;
    height: auto;
    object-fit: cover;
  }

  .colorful {
    color: #71fffd;
    background: none;
    -webkit-text-fill-color: currentColor;
  }

  .hero-image-wrapper::before {
    width: 300px;
    height: 300px;
  }
}

@media (min-width: 768px) {
  .hero-image img {
    width: 400px;
    height: 400px;
    border-radius: 100%;
    object-fit: cover;
    object-position: top;
  }
}
</style>
