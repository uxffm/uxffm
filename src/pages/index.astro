---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import WordPressReview from '~/components/widgets/WordPressReview.astro';

const metadata = {
  title: 'WordPress Agentur Frankfurt | Webseiten, SEO & Support',
  description:
    'WordPress Agentur Frankfurt für schnelle, moderne und suchmaschinenoptimierte Webseiten. WordPress Webdesign, Relaunch, Wartung, SEO und Support aus einer Hand.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->


  <div class="hero-image-wrapper">
    <div class="hero-image">
      <img src="/images/wordpress-webseite-frankfurt.webp" alt="WordPress Agentur Frankfurt">
    </div>
  </div>

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Kontakt',
        href: '/kontakt',
        target: '',
        icon: 'tabler:mail',
      },
      { text: 'Anrufen',
        href: 'tel:+49-162-7519335',
        icon: 'tabler:phone',
      },
    ]}
  >
    <Fragment slot="title">
      WordPress Agentur <span class="hidden xl:inline"></span>
      <span class="text-accent dark:text-white highlight"> Frankfurt </span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="block mb-1 sm:hidden font-bold text-blue-600">WordPress, das sauber läuft.</span>
      <span class="colorful">Ihre WordPress Agentur in Frankfurt am Main.</span>
      Wir erstellen, optimieren und betreuen WordPress-Webseiten, die schnell laden, bei Google gefunden werden und Anfragen bringen. Direkt aus Frankfurt, mit klarer Beratung, sauberer Umsetzung und Support, der nicht nach dem Launch verschwindet.
    </Fragment>
  </Hero>

  <WordPressReview />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="WORDPRESS SERVICES"
    title="WordPress Leistungen für Unternehmen in Frankfurt"
    subtitle="Ob neue Website, Relaunch oder laufende Betreuung: Wir verbinden WordPress Webdesign, Technik, SEO und Wartung zu einer Website, die im Alltag funktioniert."
    classes={{
      wrapper: 'bg-slate-100/50 dark:bg-purple-900/20'
    }}
    items={[
      {
        title: 'WordPress Webseite erstellen',
        description:
          'Wir planen und bauen moderne WordPress-Webseiten für Selbstständige, Praxen, lokale Dienstleister und Unternehmen in Frankfurt. Klar strukturiert, mobiloptimiert und einfach pflegbar.',
        icon: 'tabler:world-www',
      },
      {
        title: 'WordPress Relaunch',
        description:
          'Ihre bestehende Seite ist langsam, unübersichtlich oder technisch veraltet? Wir erneuern Design, Struktur und Technik, ohne wichtige Inhalte und SEO-Signale aus den Augen zu verlieren.',
        icon: 'tabler:refresh',
      },
      {
        title: 'WordPress SEO Frankfurt',
        description:
          'Wir optimieren Seitenstruktur, Ladezeit, Inhalte, Meta-Daten und lokale Signale, damit Ihre WordPress-Seite für relevante Suchanfragen in Frankfurt besser gefunden wird.',
        icon: 'tabler:search',
      },
      {
        title: 'Wartung & Sicherheit',
        description:
          'Updates, Backups, Security-Checks und Monitoring sorgen dafür, dass Ihre Website stabil bleibt. Wir kümmern uns um die Technik, bevor kleine Fehler groß werden.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Performance Optimierung',
        description:
          'Schnelle WordPress-Webseiten ranken besser und fühlen sich professioneller an. Wir optimieren Bilder, Caching, Theme, Plugins und Core Web Vitals.',
        icon: 'tabler:speedboat',
      },
      {
        title: 'WooCommerce & Erweiterungen',
        description:
          'Von Kontaktformularen bis WooCommerce: Wir erweitern WordPress gezielt um Funktionen, die Ihr Geschäft wirklich braucht, statt die Seite mit Plugins zu überladen.',
        icon: 'tabler:shopping-cart',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Warum WordPress?"
    title="Eine Website, die Sie wirklich nutzen können"
    items={[
    {
      title: 'Einfach zu pflegen',
      description:
        'Sie können Texte, Bilder, Blogbeiträge und wichtige Inhalte selbst bearbeiten. Wir richten WordPress so ein, dass Sie nicht für jede kleine Änderung technische Hilfe brauchen.',
    },
    {
      title: 'Technisch sauber umgesetzt',
      description:
        'Wir achten auf Ladezeit, Sicherheit, saubere Struktur, mobile Darstellung und nachhaltige Erweiterbarkeit. Die Website soll nicht nur beim Launch gut aussehen.',
    },
    {
      title: 'Auf Sichtbarkeit ausgelegt',
      description:
        'SEO fließt von Anfang an ein: Seitenarchitektur, lokale Keywords, interne Verlinkung, strukturierte Inhalte und schnelle Ladezeiten arbeiten zusammen.',
    },
    ]}
    image={{
      src: '/images/wordpress-webseite-erstellen-frankfurt.webp',
      alt: 'WordPress Webseite erstellen Frankfurt',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">WordPress für Frankfurt, nicht für die Schublade</h3>
      Eine gute Website ist mehr als ein schönes Layout. Sie erklärt Ihr Angebot, schafft Vertrauen und macht es Besuchern leicht, Kontakt aufzunehmen.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Klarer Prozess',
        description: `Wir starten mit Zielen, Zielgruppen und Suchintentionen. Danach entstehen Struktur, Design, Inhalte und technische Umsetzung in einem nachvollziehbaren Ablauf.`,
      },
      {
        title: 'Direkter Ansprechpartner',
        description:
          'Sie sprechen direkt mit jemandem, der Strategie, WordPress und SEO versteht. Kurze Wege machen Entscheidungen einfacher und Projekte schneller.',
      },
      {
        title: 'Betreuung nach dem Launch',
        description:
          "Nach dem Go-live lassen wir Sie nicht allein. Wir bieten Wartung, Updates, SEO-Optimierung, neue Landingpages und laufende Verbesserungen.",
      },
    ]}
    image={{
      src: 'images/frankfurt-am-main-commerzbank.webp',
      alt: 'WordPress Agentur Frankfurt am Main',
    }}
  >
    <Fragment slot="content">Ihre WordPress Agentur für Frankfurt am Main, Offenbach, Wiesbaden und das Rhein-Main-Gebiet.</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

   <!-- Features2 Widget ************** -->

   <Features2
   title="Was Ihre WordPress Website bekommt"
   subtitle="Die wichtigsten Bausteine für einen professionellen Auftritt"
   columns={3}
   items={[
     {
       title: 'Strategie & Seitenstruktur',
       description:
         'Wir klären, welche Seiten Sie brauchen, welche Suchbegriffe wichtig sind und wie Besucher schnell zur Anfrage kommen.',
       icon: 'tabler:sitemap',
     },
     {
       title: 'WordPress Webdesign',
       description:
         'Modernes Design mit klarer Nutzerführung, responsiven Layouts und einem Look, der zu Ihrem Unternehmen passt.',
       icon: 'tabler:device-laptop',
     },
     {
       title: 'Technisches SEO',
       description: `Saubere URLs, Meta-Daten, strukturierte Überschriften, interne Verlinkung und technische Grundlagen für bessere Indexierung.`,
       icon: 'tabler:settings-search',
     },
     {
       title: 'SEO-Texte & Inhalte',
       description:
         'Wir schreiben oder überarbeiten Inhalte, die Ihr Angebot verständlich machen und auf lokale Suchanfragen in Frankfurt einzahlen.',
       icon: 'tabler:writing',
     },
     {
       title: 'Schnelles WordPress',
       description:
         'Optimierte Bilder, schlankes Setup, Caching und reduzierte Plugin-Last für bessere Ladezeiten und eine bessere Nutzererfahrung.',
       icon: 'tabler:gauge',
     },
     {
       title: 'WooCommerce Shops',
       description:
         'Produktseiten, Kategorien, Checkout, Zahlungsarten und Shop-SEO für lokale oder überregionale WooCommerce-Projekte.',
       icon: 'tabler:shopping-cart',
     },
     {
       title: 'Local SEO Frankfurt',
       description:
         'Optimierung für lokale Suchanfragen, Standortsignale und Seiten, die Interessenten aus Frankfurt gezielt abholen.',
       icon: 'tabler:map-pin',
     },
     {
       title: 'Wartung & Updates',
       description: `Regelmäßige Updates, Backups, Sicherheitsprüfungen und technische Betreuung, damit Ihre WordPress-Seite stabil bleibt.`,
       icon: 'tabler:tool',
     },
     {
       title: 'Conversion Optimierung',
       description:
         'Kontaktwege, Formulare, Call-to-Actions und Vertrauenselemente werden so platziert, dass aus Besuchern eher Anfragen werden.',
       icon: 'tabler:chart-line',
     },
   ]}
 />

  <FAQs
    title="WordPress Agentur Frankfurt – häufige Fragen"
    subtitle="Kurz beantwortet, damit Sie schneller einschätzen können, ob WordPress für Ihr Projekt passt."
    columns={1}
    items={[
      {
        title: 'Was macht eine WordPress Agentur in Frankfurt?',
        description:
          'Wir planen, gestalten, erstellen und betreuen WordPress-Webseiten für Unternehmen in Frankfurt. Dazu gehören Webdesign, technische Umsetzung, SEO, Ladezeitoptimierung, Wartung und Support.',
      },
      {
        title: 'Ist WordPress für lokale Unternehmen geeignet?',
        description:
          'Ja. WordPress eignet sich sehr gut für Praxen, Kanzleien, Handwerker, Berater, lokale Dienstleister und B2B-Unternehmen, weil Inhalte flexibel gepflegt und für lokale Google-Suchen optimiert werden können.',
      },
      {
        title: 'Könnt ihr eine bestehende WordPress-Seite überarbeiten?',
        description:
          'Ja. Wir können eine bestehende Seite technisch prüfen, Ladezeiten verbessern, Inhalte neu strukturieren, das Design modernisieren und SEO-Probleme beheben.',
      },
      {
        title: 'Bietet ihr auch WordPress Wartung an?',
        description:
          'Ja. Auf Wunsch übernehmen wir Updates, Backups, Sicherheitsprüfungen, Fehlerbehebung und laufende Optimierung, damit Ihre Website langfristig stabil bleibt.',
      },
    ]}
  />

   <!-- HighlightedPosts Widget ******* -->

   <BlogLatestPosts
   title="Aktuelle WordPress Neuigkeiten"
   category="wordpress"
   count={6}
   classes={{
     wrapper: 'bg-gradient-to-b from-purple-50 to-blue-50 dark:from-purple-900/20 dark:to-slate-900',
   }}
 />


  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Kostenloses Erstgespräch',
        href: '/kontakt',
        target: '',
        icon: 'tabler:message',
      },
    ]}
  >
    <Fragment slot="title">
      Bereit für eine bessere WordPress Website?<br class="block sm:hidden" /> <span class="sm:whitespace-nowrap">Lass uns sprechen!</span>
    </Fragment>

    <Fragment slot="subtitle">
      Wir melden uns innerhalb von 24 Stunden bei Ihnen zurück. Ihre Anfrage ist unverbindlich und kostenlos.
    </Fragment>
  </CallToAction>
</Layout>


<style>
/* Hero Image Improvements */
.hero-image-wrapper {
  position: relative;
  margin-bottom: 1rem;
}

.hero-image-wrapper::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 450px;
  height: 450px;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(219, 39, 119, 0.1));
  border-radius: 50%;
  filter: blur(80px);
  z-index: -1;
  animation: pulse 4s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.1); }
}

.hero-image {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.hero-image img {
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  border: 4px solid rgba(139, 92, 246, 0.2);
}

.hero-image img:hover {
  transform: scale(1.02);
  box-shadow: 0 20px 60px rgba(139, 92, 246, 0.3);
}

.colorful {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 700;
}

@media (max-width: 768px) {
  .hero-image {
    height: 40vh;
    margin-bottom: 20px;
  }

  .hero-image img {
    max-width: 100%;
    height: auto;
    object-fit: cover;
  }

  .colorful {
    color: #71fffd;
    background: none;
    -webkit-text-fill-color: currentColor;
  }

  .hero-image-wrapper::before {
    width: 300px;
    height: 300px;
  }
}

@media (min-width: 768px) {
  .hero-image img {
    width: 400px;
    height: 400px;
    border-radius: 100%;
    object-fit: cover;
    object-position: top;
  }
}
</style>
