---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';
import Content from '~/components/widgets/Content.astro';
import Features3 from '~/components/widgets/Features3.astro';
import FAQs from '~/components/widgets/FAQs.astro';



const metadata = {
  title: 'Suchmaschinenmarketing Frankfurt (SEM) SEA vom Experten - FrankfurtMarketingStudio',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Ihr SEM Experte"
    title="Suchmaschinenmarketing Frankfurt"
    subtitle="Skalierbare Neukundengewinnung für B2B und B2C im Rhein-Main-Gebiet. Ich verwandle Ihr Werbebudget in messbaren Umsatz durch SEO und SEA. Mit Google Analytics 4, Google Tag Manager und professionellem Tracking-Setup. DSGVO-konform und auf maximale Budget-Effizienz optimiert."
    actions={[{ variant:"primary", target: '_blank', text: 'Jetzt anfragen!', href: '/kontakt' }]}
  />

  <!-- Review Section **************** -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-0 pb-12">
    <div class="review-card glass rounded-2xl p-8 md:p-10 shadow-xl border-2" style="border-color: #a649f6;" itemscope itemtype="https://schema.org/Review">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <img
            src="/kunde-frankfurt.png"
            alt="Suchmaschinenmarketing Kunde"
            class="w-16 h-16 rounded-full object-cover border-2"
            style="border-color: #a649f6;"
            itemprop="image"
          />
        </div>
        <div class="flex-1">
          <blockquote class="text-lg md:text-xl text-gray-700 dark:text-gray-300 leading-relaxed mb-4" itemprop="reviewBody">
            "Suchmaschinenmarketing war bei uns ein voller Erfolg. Danke an Lukasz und das Team. Das habt ihr echt gut gemacht!"
          </blockquote>
          <div class="flex items-center justify-between flex-wrap gap-4">
            <div class="flex items-center gap-2">
              <div class="flex text-yellow-400" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
                <meta itemprop="ratingValue" content="5" />
                <meta itemprop="bestRating" content="5" />
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              </div>
              <span class="text-sm text-gray-700 dark:text-gray-300 font-medium ml-2" itemprop="author" itemscope itemtype="https://schema.org/Person">
                <span itemprop="name">Dani aus Frankfurt</span> - Verifizierte Bewertung
              </span>
            </div>
            <a
              href="https://g.page/r/CQEqUnits4KBEAQ/review"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-purple-600 dark:text-purple-400 hover:text-purple-700 dark:hover:text-purple-300 transition-colors"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
              Auf Google ansehen
            </a>
          </div>
        </div>
      </div>
      <meta itemprop="itemReviewed" itemscope itemtype="https://schema.org/LocalBusiness" content="Suchmaschinenmarketing Frankfurt"/>
    </div>
  </div>

    <!-- Content Widget **************** -->

    <Content
    isAfterContent
      items={[
        {
          title: 'Ihre Konkurrenz ist in Google sichtbar. Sie nicht?',
          description:
            'Während andere Unternehmen in Frankfurt bei Google auf der ersten Seite stehen, sind Sie nirgends zu finden. Potenzielle Kunden suchen nach Ihren Dienstleistungen, finden aber nur Ihre Mitbewerber. Jeden Tag verlierst Sie Anfragen, Leads und Umsatz an die Konkurrenz. Ohne strategisches Suchmaschinenmarketing bleibst Sie unsichtbar und das kostet Sie bares Geld.',
          icon: 'tabler:eye-off',
        },
        {
          title: 'Sie investierst in Online-Marketing, siehst aber keine Ergebnisse?',
          description:
            'Vielleicht haben Sie schon in SEO oder Google Ads investiert, aber die Resultate lassen auf sich warten. Ihre Rankings stagnieren, die Anzeigen bringen keine qualifizierten Leads, und das Budget rinnt Ihnen durch die Finger. Ohne die richtige Strategie und Expertise verschwendest Sie nur Zeit und Geld. Sie brauchst jemanden, der weiß, wie Suchmaschinenmarketing wirklich funktioniert.',
          icon: 'tabler:trending-down',
        },
        {
          title: 'Sie weißt nicht, wo Sie anfangen sollst?',
          description:
            'SEO, SEA, Google Ads, Keywords, Landingpages, Conversion-Optimierung. Die Liste ist lang und komplex. Sie willst endlich in Google gefunden werden, aber Sie wissen nicht, welche Maßnahmen wirklich Sinn machen. Soll ich erst SEO machen oder direkt Anzeigen schalten? Welche Keywords sind die richtigen? Wie messe ich den Erfolg? Genau hier brauchen Sie einen Experten, der Ihnen den Weg zeigt.',
          icon: 'tabler:question-mark',
        },

      ]}
      image={{
        src: '/images/suchmaschinenmarketing-in-frankfurt.jpg',
        alt: 'Suchmaschinenmarketing für mehr Sichtbarkeit in Frankfurt',
      }}
    >
      <Fragment slot="content">
        <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Mehr Sichtbarkeit, mehr Kunden – mit SEM aus Frankfurt</h3>
      </Fragment>
    </Content>



    <!-- Content Widget **************** -->

    <Content
        isReversed
          items={[
            {
              title: 'Professionelles Tracking-Setup',
              description:
                'Ob WordPress, Shopify, Shopware oder Typo3 – ich richte Google Analytics 4 (GA4) und den Google Tag Manager so ein, dass wir Ihren ROAS (Return on Ad Spend) exakt messen können. Natürlich DSGVO-konform mit korrektem Consent Mode. Sie siehst genau, welche Kampagnen performen und wo Sie nachsteuern musst.',
              icon: 'tabler:chart-bar',
            },
            {
              title: 'Regionale Sichtbarkeit im Rhein-Main-Gebiet',
              description:
                'Als Ihr persönlicher Ansprechpartner im Rhein-Main-Gebiet sorge ich für regionale Sichtbarkeit. Ich optimiere Ihr Google Unternehmensprofil (früher Google My Business) und Ihr Google Maps Ranking, damit Kunden aus Frankfurt und Umgebung Sie sofort finden, wenn sie das Smartphone zücken. Local SEO für maximale Reichweite vor Ort.',
              icon: 'tabler:map-pin',
            },
            {
              title: 'Skalierbare Neukundengewinnung',
              description:
                'Ich kombiniere SEO und SEA zu einer effektiven Strategie für Ihre Lead-Generierung. Langfristig baue ich Ihre organischen Rankings aus, kurzfristig bringe ich Ihnen mit Google Ads sofort qualifizierte Leads. Ob B2B oder B2C, Dienstleister oder E-Commerce – ich maximiere Ihre Budget-Effizienz und sorge für kontinuierliches Wachstum.',
              icon: 'tabler:target',
            },

          ]}
          image={{
            src: '/images/suchmaschinenmarketing-in-frankfurt-2.jpg',
            alt: 'Suchmaschinenmarketing Strategie für Frankfurt',
          }}
        >
          <Fragment slot="content">
            <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Mein Ansatz: SEO + SEA = Erfolg</h3>
          </Fragment>
    </Content>





  <!-- Features3 Widget ************** -->

  <Features3
    title="Suchmaschinenmarketing Frankfurt – Meine Leistungen"
    subtitle="Alles, was Sie brauchen, um bei Google erfolgreich zu sein"
    columns={2}
    items={[
      {
        title: 'Keyword-Recherche & Analyse',
        description: 'Die Basis jeder SEM-Strategie: Ich finde heraus, welche Keywords Ihre Zielgruppe in Frankfurt wirklich nutzt. Nicht die generischen Begriffe mit Millionen Suchvolumen, sondern die relevanten, kaufbereiten Keywords, die Ihnen qualifizierte Leads bringen. Mit professionellen Tools und lokalem Know-how.',
        icon: 'tabler:search',
      },
      {
        title: 'Suchmaschinenoptimierung (SEO)',
        description: 'Langfristig organisch gefunden werden – das ist das Ziel von SEO. Ich optimiere Ihre Website technisch und inhaltlich, baue hochwertige Backlinks auf und sorge dafür, dass Google Sie liebt. On-Page, Off-Page, Local SEO – alles aus einer Hand. Nachhaltig und messbar.',
        icon: 'tabler:seo',
      },
      {
        title: 'Google Ads (SEA)',
        description: 'Sie brauchst schnelle Ergebnisse? Mit Google Ads schalte ich zielgerichtete Anzeigen, die genau dann erscheinen, wenn potenzielle Kunden nach Ihren Leistungen suchen. Ich manage Ihre Kampagnen, optimiere Gebote, texte Anzeigen und sorge für maximale Conversions bei minimalem Budget-Verschleiß.',
        icon: 'tabler:ad',
      },
      {
        title: 'Local SEO für Frankfurt',
        description: 'Für lokale Unternehmen ist Local SEO entscheidend. Ich optimiere Ihr Google-Unternehmensprofil, baue lokale Citations auf und sorge dafür, dass Sie bei „[Branche] Frankfurt" ganz oben stehst. Perfekt für Dienstleister, Praxen, Restaurants und Läden mit lokalem Kundenstamm.',
        icon: 'tabler:map-pin-filled',
      },
      {
        title: 'Conversion-Optimierung (CRO)',
        description: 'Traffic allein bringt nichts – er muss auch konvertieren. Ich analysiere Ihre Website und Landingpages, identifiziere Schwachstellen und optimiere sie für maximale Conversions. Bessere Texte, klarere Call-to-Actions, optimierte Formulare – damit aus Besuchern Kunden werden.',
        icon: 'tabler:click',
      },
      {
        title: 'Content-Marketing',
        description: 'Content ist King – besonders für SEO. Ich erstelle oder optimiere Inhalte, die Ihre Zielgruppe wirklich interessieren und gleichzeitig bei Google ranken. Blog-Artikel, Landingpages, Produktbeschreibungen – alles SEO-optimiert, authentisch und verkaufsstark.',
        icon: 'tabler:writing',
      },
      {
        title: 'Technisches SEO',
        description: 'Eine Website muss technisch einwandfrei sein, damit Google sie liebt. Ich prüfe Ladezeiten, Mobile-Optimierung, strukturierte Daten, XML-Sitemaps und behebe technische Fehler. Schnell, sauber, crawlbar – so wie Google es mag.',
        icon: 'tabler:tool',
      },
      {
        title: 'Linkaufbau & Backlinks',
        description: 'Hochwertige Backlinks sind nach wie vor ein wichtiger Ranking-Faktor. Ich baue für Sie saubere, relevante Links auf – keine dubiosen Linkfarmen, sondern echte, wertvolle Verlinkungen von themenrelevanten Websites. Nachhaltig und sicher.',
        icon: 'tabler:link',
      },
      {
        title: 'Reporting & Analyse',
        description: 'Sie bekommst regelmäßige Reports mit allen wichtigen KPIs: Rankings, Traffic, Conversions, Kosten pro Lead und mehr. Ich zeige Ihnen transparent, was funktioniert und wo wir nachjustieren müssen. Datenbasiertes Marketing, kein Bauchgefühl.',
        icon: 'tabler:report',
      },
      {
        title: 'Wettbewerbsanalyse',
        description: 'Was macht Ihre Konkurrenz in Frankfurt? Welche Keywords ranken bei ihnen? Welche Anzeigen schalten sie? Ich analysiere Ihre Mitbewerber und finde heraus, wo Ihre Chancen liegen. So sind Sie der Konkurrenz immer einen Schritt voraus.',
        icon: 'tabler:users',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />



  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Suchmaschinenmarketing Frankfurt – FAQs"
    subtitle="Falls Sie weitere Fragen zu SEM hast, hoffe ich, die wichtigsten hier beantwortet zu haben. Andernfalls schreib mir gerne eine Nachricht."
    columns={1}
    items={[
      {
        title: 'Was ist der Unterschied zwischen SEO und SEA?',
        description:
          'SEO (Search Engine Optimization) ist die organische Suchmaschinenoptimierung. Sie verbesserst Ihre Website, um langfristig in den unbezahlten Suchergebnissen aufzutauchen. SEA (Search Engine Advertising) sind bezahlte Anzeigen, z.B. Google Ads. Sie zahlst pro Klick und erscheinst sofort in den Suchergebnissen. Beide Ansätze haben Vor- und Nachteile. Ideal ist eine Kombination aus beidem: SEO für langfristigen Erfolg, SEA für schnelle Ergebnisse.',
      },
      {
        title: 'Wie lange dauert es, bis ich Ergebnisse sehe?',
        description:
          'Bei SEA (Google Ads) siehst Sie erste Ergebnisse innerhalb weniger Tage – sobald die Kampagnen live sind. Bei SEO dauert es länger, typischerweise 3–6 Monate, bis deutliche Ranking-Verbesserungen sichtbar werden. SEO ist ein Marathon, keine Sprint. Dafür sind die Ergebnisse nachhaltig und kosten Sie langfristig weniger als ständig neue Anzeigen zu schalten.',
      },
      {
        title: 'Was kostet Suchmaschinenmarketing?',
        description:
          'Die Kosten hängen stark vom Umfang ab. SEO-Betreuung startet ab ca. 500–1.000 € pro Monat, je nach Wettbewerb und Zielen. Google Ads-Budget ist variabel – Sie legst fest, wie viel Sie ausgeben möchtest (z.B. 500–2.000 € pro Monat). Dazu kommt ggf. meine Management-Gebühr. Ich erstelle Ihnen gerne ein individuelles Angebot basierend auf Ihren Zielen und Ihrem Budget.',
      },
      {
        title: 'Lohnt sich SEM für kleine Unternehmen in Frankfurt?',
        description:
          'Absolut! Gerade für kleine und mittelständische Unternehmen ist lokales Suchmaschinenmarketing extrem effektiv. Wenn jemand nach „Steuerberater Frankfurt Sachsenhausen" oder „Friseur Nordend" sucht, ist das ein hochqualifizierter Lead. Mit der richtigen Strategie können Sie auch mit kleinem Budget viel erreichen – besonders mit Local SEO und gezielten Google Ads Kampagnen.',
      },
      {
        title: 'Brauche ich SEO oder Google Ads – oder beides?',
        description:
          'Idealerweise beides. Google Ads bringt Ihnen sofort Traffic und Anfragen – perfekt, wenn Sie schnell starten willst. SEO braucht länger, zahlt sich aber langfristig aus und kostet Sie keine Klickpreise mehr. Meine Empfehlung: Starte mit Google Ads für Quick Wins und baue parallel Ihr SEO auf. So deckst Sie kurz- und langfristig ab.',
      },
      {
        title: 'Kann ich SEM selbst machen oder brauche ich einen Experten?',
        description:
          'Grundlagen können Sie Ihnen selbst aneignen, aber professionelles SEM erfordert viel Erfahrung, Zeit und Know-how. Von der Keyword-Recherche über technisches SEO bis hin zur Optimierung von Anzeigen-Geboten – jeder Schritt will gelernt sein. Ein Experte spart Ihnen Zeit, vermeidet teure Fehler und holt mehr aus Ihrem Budget heraus. Sie konzentrieren Sie sich auf Ihr Business, ich auf Ihre Sichtbarkeit.',
      },
    ]}
  />



  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[{
      variant: "primary",
      text: 'Jetzt unverbindlich anfragen!',
      href: '/kontakt',
    }]}
    title="Bereit für mehr Sichtbarkeit in Frankfurt?"
    subtitle="Schreib mir ganz unverbindlich eine Nachricht und lass uns über Ihre SEM-Strategie sprechen – Ihr Online-Marketing Experte Lukasz aus Frankfurt."
  />
</Layout>



<style>
  .wrapper {
    max-width: 800px;
    margin: 0px auto;
    padding: 0 1rem;
  }

  .wrapper:nth-child(3) {
    margin-top: 64px;
  }

  .ul-list {
    list-style: disc;
    padding-left: 20px;
    margin-top: 8px;
  }


  a {
    text-decoration: underline;
    color: white;
  }
</style>
