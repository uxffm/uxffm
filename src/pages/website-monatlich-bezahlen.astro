---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';
import Content from '~/components/widgets/Content.astro';
import Features3 from '~/components/widgets/Features3.astro';
import FAQs from '~/components/widgets/FAQs.astro';



const metadata = {
  title: 'Website monatlich bezahlen - Flexible Webseiten ohne hohe Anfangskosten - FrankfurtMarketingStudio',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Ihre Website auf Raten"
    title="Website monatlich bezahlen"
    subtitle="Eine professionelle Website ohne hohe Anfangsinvestition – mit monatlicher Zahlung kommst Sie schnell und flexibel zu Ihrer Online-Präsenz. Ideal für Selbstständige, kleine Unternehmen und Startups in Frankfurt, die ihr Budget schonen möchten."
    actions={[{ variant:"primary", target: '_blank', text: 'Jetzt anfragen!', href: '/kontakt' }]}
  />


    <!-- Content Widget **************** -->

    <Content
    isAfterContent
      items={[
        {
          title: 'Hohe Anfangskosten schrecken Sie ab?',
          description:
            'Eine professionelle Website kostet oft mehrere tausend Euro auf einmal. Gerade für Gründer, Selbstständige oder kleine Unternehmen ist diese Investition eine große finanzielle Belastung. Sie zögerst, weil Sie das Geld im Moment nicht flüssig hast – obwohl Sie wissen, dass eine Website wichtig für Ihr Business ist. Ohne Online-Präsenz verlierst Sie aber täglich potenzielle Kunden an Ihre Konkurrenz.',
          icon: 'tabler:coin-off',
        },
        {
          title: 'Sie brauchst Planungssicherheit?',
          description:
            'Mit festen monatlichen Kosten behältst Sie die volle Kontrolle über Ihre Ausgaben. Keine bösen Überraschungen, keine versteckten Zusatzkosten. Sie weißt genau, was jeden Monat auf Sie zukommt und kannst Ihr Budget entsprechend planen. Das gibt Ihnen die Sicherheit, die Sie für Ihr Business brauchst.',
          icon: 'tabler:calendar-check',
        },
        {
          title: 'Sie willst schnell starten?',
          description:
            'Warum Monate sparen, wenn Sie sofort loslegen kannst? Mit monatlicher Zahlung bekommst Sie Ihre professionelle Website jetzt – ohne lange zu warten. Ihr Online-Auftritt steht in wenigen Wochen, und Sie können sofort anfangen, Kunden zu gewinnen. Zeit ist Geld, besonders im Business.',
          icon: 'tabler:rocket',
        },

      ]}
    >
      <Fragment slot="content">
        <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Professionelle Website – bezahlbar für jeden</h3>
      </Fragment>
    </Content>



    <!-- Content Widget **************** -->

    <Content
        isReversed
          items={[
            {
              title: 'Flexibles Zahlungsmodell',
              description:
                'Statt einer großen Einmalzahlung verteilst Sie die Kosten auf monatliche Raten. Das schont Ihre Liquidität und ermöglicht Ihnen, sofort mit Ihrer Website durchzustarten. Sie zahlst einen festen monatlichen Betrag und bekommst dafür eine vollwertige, professionelle Website – inklusive Hosting, Wartung und Support.',
              icon: 'tabler:credit-card',
            },
            {
              title: 'Alles inklusive – keine versteckten Kosten',
              description:
                'In Ihrer monatlichen Rate ist bereits alles enthalten: Design, Entwicklung, Hosting, SSL-Zertifikat, regelmäßige Updates und technischer Support. Sie musst Sie um nichts kümmern – ich übernehme die komplette Betreuung Ihrer Website. So können Sie Sie voll auf Ihr Geschäft konzentrieren.',
              icon: 'tabler:package',
            },
            {
              title: 'Keine Bindung, volle Flexibilität',
              description:
                'Die meisten Ratenzahlungsmodelle laufen über 12, 24 oder 36 Monate – je nachdem, was zu Ihnen passt. Danach gehört die Website Ihnen, oder Sie verlängerst einfach den Service-Vertrag für laufende Betreuung. Keine ewige Bindung, keine komplizierten Verträge – nur faire, transparente Konditionen.',
              icon: 'tabler:lock-open',
            },

          ]}
        >
          <Fragment slot="content">
            <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">So funktioniert die monatliche Zahlung</h3>
          </Fragment>
    </Content>





  <!-- Features3 Widget ************** -->

  <Features3
    title="Website monatlich bezahlen – Was ist enthalten?"
    subtitle="Ihr All-in-One-Paket für eine professionelle Online-Präsenz"
    columns={2}
    items={[
      {
        title: 'Individuelles Webdesign',
        description: 'Keine 08/15-Vorlage, sondern ein maßgeschneidertes Design, das zu Ihrer Marke passt. Modern, responsive und benutzerfreundlich – auf allen Geräten perfekt dargestellt. Ihre Website hebt sich von der Masse ab und hinterlässt einen bleibenden Eindruck bei Ihren Besuchern.',
        icon: 'tabler:palette',
      },
      {
        title: 'Professionelle Entwicklung',
        description: 'Technisch sauber programmiert, schnell ladend und suchmaschinenoptimiert. Ich setze auf moderne Technologien und Best Practices, damit Ihre Website nicht nur gut aussieht, sondern auch performant und sicher läuft. Perfekt für Google und Ihre Nutzer.',
        icon: 'tabler:code',
      },
      {
        title: 'Hosting & Domain inklusive',
        description: 'Sie brauchst Sie um nichts zu kümmern. Hosting, Domain-Einrichtung, SSL-Zertifikat – alles ist in Ihrer monatlichen Rate enthalten. Ihre Website läuft auf schnellen, sicheren Servern und ist rund um die Uhr erreichbar.',
        icon: 'tabler:server',
      },
      {
        title: 'Regelmäßige Updates & Wartung',
        description: 'Software-Updates, Sicherheits-Patches, Backups – ich halte Ihre Website immer auf dem neuesten Stand. Sie musst Sie um keine technischen Details kümmern. Ihre Website bleibt sicher, schnell und aktuell.',
        icon: 'tabler:refresh',
      },
      {
        title: 'Content Management System (CMS)',
        description: 'Mit einem benutzerfreundlichen CMS wie WordPress können Sie Texte und Bilder später selbst anpassen – ganz ohne Programmierkenntnisse. Ich richte alles für Sie ein und zeige Ihnen, wie es funktioniert. So bleibst Sie flexibel und unabhängig.',
        icon: 'tabler:edit',
      },
      {
        title: 'SEO-Optimierung',
        description: 'Ihre Website wird von Anfang an für Suchmaschinen optimiert. Schnelle Ladezeiten, sauberer Code, Meta-Tags und strukturierte Daten – alles, was Google liebt. So haben Sie die besten Chancen, bei lokalen Suchanfragen in Frankfurt gefunden zu werden.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Mobile Optimierung',
        description: 'Über 60% der Nutzer surfen heute mobil. Ihre Website ist responsive und sieht auf Smartphone, Tablet und Desktop perfekt aus. Egal, wo Ihre Kunden Sie finden – sie bekommen immer das beste Erlebnis.',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'Kontaktformulare & Funktionen',
        description: 'Ich integriere alle Funktionen, die Sie brauchen: Kontaktformulare, Google Maps, Social-Media-Links, Newsletter-Anmeldung und mehr. Ihre Website ist nicht nur schön, sondern auch funktional und hilft Ihnen, Leads zu generieren.',
        icon: 'tabler:mail',
      },
      {
        title: 'Technischer Support',
        description: 'Bei Fragen oder Problemen bin ich für Sie da. Schneller, persönlicher Support – kein Callcenter, sondern direkter Draht zum Entwickler. Ich helfe Ihnen, wenn Sie etwas brauchst oder Anpassungen möchtest.',
        icon: 'tabler:headset',
      },
      {
        title: 'Google Analytics & Tracking',
        description: 'Ich richte Google Analytics und andere Tracking-Tools für Sie ein, damit Sie genau siehst, wie Ihre Website performt. Wie viele Besucher kommen? Woher? Was machen sie? Diese Daten helfen Ihnen, Ihre Online-Strategie zu optimieren.',
        icon: 'tabler:chart-dots',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />



  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Website monatlich bezahlen – Häufige Fragen"
    subtitle="Falls Sie weitere Fragen zur monatlichen Zahlung hast, hoffe ich, die wichtigsten hier beantwortet zu haben. Andernfalls schreib mir gerne eine Nachricht."
    columns={1}
    items={[
      {
        title: 'Wie hoch sind die monatlichen Kosten?',
        description:
          'Die monatlichen Kosten hängen vom Umfang Ihrer Website ab. Eine einfache Business-Website mit 5–10 Seiten startet ab ca. 99–199 € pro Monat. Umfangreichere Projekte mit mehr Features kosten entsprechend mehr. Ich erstelle Ihnen gerne ein individuelles Angebot, das genau zu Ihren Anforderungen und Ihrem Budget passt.',
      },
      {
        title: 'Wie lange läuft der Vertrag?',
        description:
          'Typischerweise läuft der Vertrag über 12, 24 oder 36 Monate – je nachdem, was für Sie am besten passt. Je länger die Laufzeit, desto niedriger die monatliche Rate. Nach Ablauf der Vertragslaufzeit gehört die Website Ihnen, oder wir verlängern den Service-Vertrag für laufende Betreuung.',
      },
      {
        title: 'Was passiert nach der Vertragslaufzeit?',
        description:
          'Nach Ablauf der vereinbarten Laufzeit haben Sie mehrere Optionen: Sie kannst die Website komplett übernehmen (sie gehört dann Ihnen), Sie verlängerst den Wartungsvertrag zu reduzierten Kosten, oder Sie beendest die Zusammenarbeit. Sie bist völlig frei in Ihrer Entscheidung.',
      },
      {
        title: 'Gehört mir die Website am Ende?',
        description:
          'Ja! Nach vollständiger Zahlung aller Raten gehört die Website Ihnen – inklusive aller Rechte. Sie kannst sie dann selbst weiterführen, zu einem anderen Anbieter umziehen oder weiterhin meinen Support in Anspruch nehmen. Volle Transparenz, keine versteckten Klauseln.',
      },
      {
        title: 'Kann ich Änderungen an der Website vornehmen?',
        description:
          'Ja, auf jeden Fall! Kleinere Anpassungen (Texte, Bilder austauschen) können Sie über das CMS selbst vornehmen. Für größere Änderungen oder neue Features unterstütze ich Sie gerne – entweder im Rahmen des Service-Pakets oder gegen Aufpreis, je nach Umfang.',
      },
      {
        title: 'Ist monatliche Zahlung teurer als eine Einmalzahlung?',
        description:
          'In der Summe kann die monatliche Zahlung etwas teurer sein als eine Einmalzahlung – dafür bekommst Sie aber auch laufenden Service, Wartung und Support inklusive. Sie zahlst also nicht nur für die Website selbst, sondern auch für die Betreuung über die gesamte Laufzeit. Das spart Ihnen Zeit, Nerven und gibt Ihnen Sicherheit.',
      },
    ]}
  />



  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[{
      variant: "primary",
      text: 'Jetzt unverbindlich anfragen!',
      href: '/kontakt',
    }]}
    title="Bereit für Ihre Website mit monatlicher Zahlung?"
    subtitle="Schreib mir ganz unverbindlich eine Nachricht und ich erstelle Ihnen ein individuelles Angebot – Ihr Webdesigner Lukasz aus Frankfurt."
  />
</Layout>



<style>
  .wrapper {
    max-width: 800px;
    margin: 0px auto;
    padding: 0 1rem;
  }

  .wrapper:nth-child(3) {
    margin-top: 64px;
  }

  .ul-list {
    list-style: disc;
    padding-left: 20px;
    margin-top: 8px;
  }


  a {
    text-decoration: underline;
    color: white;
  }
</style>
