---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';


const metadata = {
  title: 'Unsere Serviceleistungen | WordPress, SEO & Marketing Frankfurt',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Service"
    title="WordPress, SEO & Marketing Service Frankfurt"
    subtitle="Hier erfährst Sie mehr über unsere Serviceleistungen. Zu unseren Serviceleistungen gehören WordPress, SEO, Webdesign und Suchmaschinenmarketing für Frankfurt."
    actions={[{ variant:"primary", target: '_blank', text: 'Jetzt anfragen!', href: '/kontakt' }]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'AstroWind Hero Image',
    }}
  />


<div class="wrapper">

<h2 class="leading-tighter text-heading text-4xl md:text-5xl font-bold leading-tighter tracking-tighter mb-4 font-heading">Unsere Services für Frankfurt</h2>

<p>Als WordPress Agentur Frankfurt bieten wir Dienstleistungen für Unternehmen, die online professioneller auftreten und besser gefunden werden wollen. WordPress, Webdesign und flexible Website-Angebote finden Sie direkt auf der Startseite. Hier bleiben die separaten SEO- und Marketing-Leistungen.</p>

<a href="/suchmaschinenoptimierung-frankfurt">
    <h2 class="leading-tighter text-heading text-4xl md:text-5xl font-bold leading-tighter tracking-tighter mb-4 font-heading">Suchmaschinenoptimierung (SEO)</h2></a>
<p>Wir optimieren Ihre Website für Google und andere Suchmaschinen, damit potenzielle Kunden Sie besser finden. Von der technischen Optimierung über hochwertigen Content bis zum Linkaufbau – wir kümmern uns um alle Aspekte der Suchmaschinenoptimierung.</p>
<ul class="ul-list">
<li>On-Page & Off-Page Optimierung</li>
<li>Technisches SEO & Performance-Optimierung</li>
<li>Content-Strategie & Keyword-Recherche</li>
<li>Local SEO für Frankfurt und Umgebung</li>
<li>Linkaufbau & Backlink-Analyse</li>
</ul>

<a href="/suchmaschinenmarketing-frankfurt">
    <h2 class="leading-tighter text-heading text-4xl md:text-5xl font-bold leading-tighter tracking-tighter mb-4 font-heading">Suchmaschinenmarketing (SEM)</h2></a>
<p>Mit professionellem Suchmaschinenmarketing kombinieren wir SEO und SEA (Google Ads) für maximale Sichtbarkeit. Schnelle Ergebnisse durch bezahlte Anzeigen plus langfristiger organischer Traffic – die perfekte Kombination.</p>
<ul class="ul-list">
<li>Google Ads Kampagnen-Management</li>
<li>Keyword-Strategie & Gebotsoptimierung</li>
<li>Conversion-Optimierung & A/B-Testing</li>
<li>Transparentes Reporting & Erfolgsmessung</li>
<li>Lokale Kampagnen für Frankfurt</li>
</ul>

</div>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[{
      variant: "primary",
      text: 'Jetzt unverbindlich anfragen!',
      href: '/kontakt',
    }]}
    title="Noch Fragen?"
    subtitle="Schreib uns ganz unverbindlich eine Nachricht und wir werden uns so schnell wie möglich bei Ihnen melden."
  />
</Layout>

<style>

a {
    text-decoration: underline;
}

  .wrapper {
    max-width: 800px;
    margin: 0px auto;
    padding: 0 1rem;
  }

  .wrapper:nth-child(3) {
    margin-top: 64px;
  }

  .ul-list {
    list-style: disc;
    padding-left: 20px;
    margin-top: 8px;
  }

  h2 {
    margin-top: 64px;
  }
</style>
